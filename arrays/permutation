public class Main {

    static void generatePermutations(String[] arr, boolean[] visited, String current, int count) {

        if (count == arr.length) {
            System.out.println(current);
            return;
        }

        for (int i = 0; i < arr.length; i++) {
            if (!visited[i]) {
                visited[i] = true;
                generatePermutations(arr, visited, current + arr[i], count + 1);
                visited[i] = false; // Backtrack
            }
        }
    }

    public static void main(String[] args) {

        String[] arr = {"ab", "cd", "ef"};
        boolean[] visited = new boolean[arr.length];

        generatePermutations(arr, visited, "", 0);
    }
}
